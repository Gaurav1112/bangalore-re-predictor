---
import '../styles/tokens.css';
import BacktestScrubber from '../components/BacktestScrubber';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Backtest — Bangalore RE Predictor</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=DM+Sans:wght@400;500&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-mono/style.css"
  />
</head>
<body style="overflow-y:auto;">
  <nav style="position:fixed;top:0;left:0;right:0;z-index:10;background:rgba(8,12,20,0.9);backdrop-filter:blur(12px);padding:12px 24px;border-bottom:1px solid rgba(240,165,0,0.12);display:flex;gap:24px;align-items:center;">
    <a href="/" style="font-family:serif;font-weight:700;color:#F0A500;text-decoration:none;font-size:16px;">BLR INVEST</a>
    <a href="/" style="color:#8898AA;text-decoration:none;font-size:13px;">← Heatmap</a>
    <span style="color:#F0F4FF;font-size:13px;">Backtest</span>
  </nav>
  <div style="padding-top:60px;">
    <BacktestScrubber client:only="react" />
  </div>
</body>
</html>
